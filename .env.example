# Slack App Credentials
# Get these from https://api.slack.com/apps

# ================================================
# OPTION A: Multi-Workspace OAuth Mode (recommended for production)
# ================================================
# Client ID (from App Settings > Basic Information)
SLACK_CLIENT_ID=your-client-id

# Client Secret (from App Settings > Basic Information)
SLACK_CLIENT_SECRET=your-client-secret

# Signing Secret (from App Credentials)
SLACK_SIGNING_SECRET=your-signing-secret

# CSRF state secret for OAuth flow (random string)
SLACK_STATE_SECRET=your-random-state-secret

# ================================================
# OPTION B: Single-Workspace Legacy Mode (for development)
# ================================================
# Only used if SLACK_CLIENT_ID and SLACK_CLIENT_SECRET are NOT set.
# Bot Token (starts with xoxb-)
# SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token for Socket Mode (starts with xapp-)
# SLACK_APP_TOKEN=xapp-your-app-token

# ================================================
# Server Configuration
# ================================================
PORT=3000
BASE_URL=http://localhost:3000

# ================================================
# Authentication
# ================================================
# Secret for signing review tokens (HMAC-SHA256)
# If not set, a random secret is generated on startup (NOT persistent across restarts)
# IMPORTANT: Set this in production for token persistence!
REVIEW_TOKEN_SECRET=your-64-char-hex-secret

# Token expiry in seconds (default: 7 days = 604800)
REVIEW_TOKEN_TTL=604800

# ================================================
# Database Configuration
# ================================================
# For production (PostgreSQL) - set this to your Render PostgreSQL internal URL
# DATABASE_URL=postgres://user:password@host:5432/database

# For local development, SQLite is used by default (no config needed)
